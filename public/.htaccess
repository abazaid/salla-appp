RewriteEngine On

# Redirect app.rankxseo.com public pages to main domain — app routes (/login, /dashboard, /admin, /api/*, ...) stay on subdomain
RewriteCond %{HTTP_HOST} ^app\.rankxseo\.com$ [NC]
RewriteRule ^(faq|pricing|privacy|terms|about)$ https://rankxseo.com/$1 [R=301,L]
RewriteCond %{HTTP_HOST} ^app\.rankxseo\.com$ [NC]
RewriteRule ^$ https://rankxseo.com/ [R=301,L]

# Ensure consistent UTF-8 charset for static/text responses.
AddDefaultCharset UTF-8
AddCharset UTF-8 .js .mjs .css .json .html .txt

# Let Apache/LiteSpeed serve existing files and directories directly.
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# Send all application routes through the front controller.
RewriteRule ^ index.php [L,QSA]
